{
  "name": "web-application-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "bootstrap:repo": "node --experimental-strip-types ./scripts/bootstrap-repo.ts",
    "commitlint": "commitlint --edit",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npm run lint:eslint && npm run lint:docs && npm run lint:sql",
    "lint:docs": "markdownlint-cli2 \"*.md\" \".github/**/*.md\" \"src/**/*.md\" \"supabase/**/*.md\"",
    "lint:eslint": "eslint .",
    "lint:sql": "sh -c 'set -- $(find supabase -type f -name \"*.sql\"); [ \"$#\" -eq 0 ] || prettier --check \"$@\"'",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run --passWithNoTests"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,sql,toml,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-query": "^5.97.0",
    "@tanstack/react-query-devtools": "^5.97.0",
    "@tanstack/react-router": "^1.168.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.97.0",
    "@tanstack/react-router-devtools": "^1.166.10",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.2",
    "prettier-plugin-sql": "^0.20.0",
    "supabase": "^2.89.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
