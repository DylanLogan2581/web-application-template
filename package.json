{
  "name": "web-application-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "bootstrap:repo": "node --experimental-strip-types ./scripts/bootstrap-repo.ts",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "npm run lint:eslint && npm run lint:docs && npm run lint:sql",
    "lint:docs": "markdownlint-cli2 \"*.md\" \".github/**/*.md\" \"src/**/*.md\" \"supabase/**/*.md\"",
    "lint:eslint": "eslint .",
    "lint:sql": "sh -c 'set -- $(find supabase -type f -name \"*.sql\"); [ \"$#\" -eq 0 ] || prettier --check \"$@\"'",
    "preview": "vite preview",
    "prepare": "husky",
    "release": "node --experimental-strip-types ./scripts/release.ts",
    "release:dry": "node --experimental-strip-types ./scripts/release.ts --dry-run",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,sql,toml,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.94.5",
    "@tanstack/react-query-devtools": "^5.94.5",
    "@tanstack/react-router": "^1.168.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@eslint-react/eslint-plugin": "^4.2.3",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-query": "^5.94.5",
    "@tanstack/react-router-devtools": "^1.166.10",
    "@tanstack/router-plugin": "^1.167.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "commitizen": "^4.3.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "prettier-plugin-sql": "^0.20.0",
    "release-it": "^20.0.0",
    "shadcn": "^4.3.1",
    "supabase": "^2.83.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.0.7"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  }
}
